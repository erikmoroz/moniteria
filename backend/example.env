POSTGRES_DB=monie_db
POSTGRES_USER=monie_user
POSTGRES_PASSWORD=monie_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
SECRET_KEY=change-me-to-random-64-char-string
JWT_SECRET_KEY=change-me-to-different-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEMO_MODE=false
REDIS_URL=redis://localhost:6379

# Legal document operator settings (for privacy policy, terms of service)
# LEGAL_OPERATOR_NAME can be a company name or individual's name
# LEGAL_OPERATOR_TYPE should be 'company' or 'individual'
LEGAL_OPERATOR_NAME=Your Company Name
LEGAL_OPERATOR_TYPE=company
LEGAL_CONTACT_EMAIL=legal@example.com
LEGAL_CONTACT_ADDRESS=
LEGAL_JURISDICTION=Your Jurisdiction

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@monie.app

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# Token max age in seconds (default: 7 days)
TOKEN_MAX_AGE=604800
